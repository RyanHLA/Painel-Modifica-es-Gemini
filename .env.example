# Supabase — obtenha em: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_PROJECT_ID="seu-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
VITE_SUPABASE_URL="https://seu-project-id.supabase.co"

# Cloudflare R2 — obtenha em: https://dash.cloudflare.com/ > R2
VITE_R2_ACCOUNT_ID="seu-account-id"
VITE_R2_BUCKET_NAME=nome-do-bucket
VITE_R2_ENDPOINT=https://seu-account-id.r2.cloudflarestorage.com
VITE_R2_PUBLIC_URL=https://pub-xxx.r2.dev
